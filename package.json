{
  "name": "t2askdock",
  "displayName": "t2askdock",
  "description": "VS Codeのタスク管理ツール拡張",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:taskDock.openTree",
    "onCommand:taskDock.openBoard",
    "onCommand:taskDock.selectDatabase",
    "onCommand:taskDock.toggleReadOnly",
    "onCommand:taskDock.createTask"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "taskDock.openTree",
        "title": "Task Dock: Open Tree"
      },
      {
        "command": "taskDock.openBoard",
        "title": "Task Dock: Open Board"
      },
      {
        "command": "taskDock.selectDatabase",
        "title": "Task Dock: Select Database"
      },
      {
        "command": "taskDock.toggleReadOnly",
        "title": "Task Dock: Toggle ReadOnly"
      },
      {
        "command": "taskDock.createTask",
        "title": "Task Dock: Create Task"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p tsconfig.extension.json",
    "watch": "tsc -watch -p tsconfig.extension.json",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "better-sqlite3": "file:vendor/better-sqlite3"
  }
}
