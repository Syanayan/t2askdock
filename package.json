{
  "name": "t2askdock",
  "displayName": "Task Dock",
  "description": "Local SQLite-based task manager. Kanban board, multi-DB support, subtasks and AI task generation. / ローカル SQLite でタスクを管理する VS Code 拡張。カンバンボード・複数DB・サブタスク・AI生成対応。",
  "publisher": "syanax",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Syanayan/t2askdock"
  },
  "keywords": [
    "task",
    "kanban",
    "todo",
    "project management",
    "sqlite",
    "productivity"
  ],
  "icon": "resources/icon.png",
  "private": false,
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskDock",
          "title": "Task Dock",
          "icon": "resources/task-dock.svg"
        }
      ]
    },
    "views": {
      "taskDock": [
        {
          "id": "taskDock.myRecentTasks",
          "name": "My Tasks"
        },
        {
          "id": "taskDock.allProjects",
          "name": "All Projects"
        }
      ]
    },
    "commands": [
      {
        "command": "taskDock.openTree",
        "title": "Task Dock: Open Tree"
      },
      {
        "command": "taskDock.openBoard",
        "title": "Task Dock: Open Board"
      },
      {
        "command": "taskDock.openTable",
        "title": "Task Dock: Open Table",
        "icon": "$(list-tree)"
      },
      {
        "command": "taskDock.selectDatabase",
        "title": "Task Dock: Select Database"
      },
      {
        "command": "taskDock.toggleReadOnly",
        "title": "Task Dock: Toggle ReadOnly"
      },
      {
        "command": "taskDock.createTask",
        "title": "Task Dock: Create Task"
      },
      {
        "command": "taskDock.openDbTable",
        "title": "Task Dock: このDBのリストを表示"
      },
      {
        "command": "taskDock.createTaskInDb",
        "title": "Task Dock: このDBにタスクを作成"
      },
      {
        "command": "taskDock.createTaskInProject",
        "title": "Task Dock: このカテゴリにタスクを作成"
      },
      {
        "command": "taskDock.createTaskFromAI",
        "title": "Task Dock: Create Task from AI"
      },
      {
        "command": "taskDock.openTaskDetail",
        "title": "Task Dock: Open Task Detail"
      },
      {
        "command": "taskDock.updateTask",
        "title": "Task Dock: Update Task"
      },
      {
        "command": "taskDock.deleteTask",
        "title": "Task Dock: Delete Task"
      },
      {
        "command": "taskDock.createSubtask",
        "title": "Task Dock: Create Subtask"
      },
      {
        "command": "taskDock.myRecentTasks.sortUpdated",
        "title": "Sort by Updated",
        "icon": "$(history)"
      },
      {
        "command": "taskDock.myRecentTasks.sortPriority",
        "title": "Sort by Priority",
        "icon": "$(flame)"
      },
      {
        "command": "taskDock.myRecentTasks.sortDeadline",
        "title": "Sort by Deadline",
        "icon": "$(calendar)"
      },
      {
        "command": "taskDock.allProjects.sortUpdated",
        "title": "Sort by Updated",
        "icon": "$(history)"
      },
      {
        "command": "taskDock.allProjects.sortPriority",
        "title": "Sort by Priority",
        "icon": "$(flame)"
      },
      {
        "command": "taskDock.allProjects.sortDeadline",
        "title": "Sort by Deadline",
        "icon": "$(calendar)"
      },
      {
        "command": "taskDock.allProjects.showDoneOnly",
        "title": "Show Done Only",
        "icon": "$(eye)"
      },
      {
        "command": "taskDock.allProjects.showActiveOnly",
        "title": "Show Active Only",
        "icon": "$(eye-closed)"
      },
      {
        "command": "taskDock.mountDatabase",
        "title": "Task Dock: DBファイルをマウント"
      },
      {
        "command": "taskDock.registerDatabaseDirectory",
        "title": "Task Dock: DBフォルダを登録"
      },
      {
        "command": "taskDock.createDatabase",
        "title": "Task Dock: 新しいDBを作成"
      }
    ],
    "configuration": {
      "title": "Task Dock",
      "properties": {
        "taskDock.userId": {
          "type": "string",
          "default": "system",
          "markdownDescription": "**My Tasks** に表示するユーザー ID。\n\nこの ID と一致する `created_by` または `assignee` を持つタスクが My Tasks に表示されます。\n\n例: `alice`、`john.doe`、自分の名前など"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "taskDock.myRecentTasks.sortUpdated",
          "when": "view == taskDock.myRecentTasks",
          "group": "navigation"
        },
        {
          "command": "taskDock.myRecentTasks.sortPriority",
          "when": "view == taskDock.myRecentTasks",
          "group": "navigation"
        },
        {
          "command": "taskDock.myRecentTasks.sortDeadline",
          "when": "view == taskDock.myRecentTasks",
          "group": "navigation"
        },
        {
          "command": "taskDock.allProjects.showActiveOnly",
          "when": "view == taskDock.allProjects && taskDock.showDone",
          "group": "navigation"
        },
        {
          "command": "taskDock.allProjects.showDoneOnly",
          "when": "view == taskDock.allProjects && !taskDock.showDone",
          "group": "navigation"
        },
        {
          "command": "taskDock.allProjects.sortUpdated",
          "when": "view == taskDock.allProjects",
          "group": "navigation"
        },
        {
          "command": "taskDock.allProjects.sortPriority",
          "when": "view == taskDock.allProjects",
          "group": "navigation"
        },
        {
          "command": "taskDock.allProjects.sortDeadline",
          "when": "view == taskDock.allProjects",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "taskDock.openTaskDetail",
          "when": "(view == taskDock.myRecentTasks || view == taskDock.allProjects) && viewItem == task",
          "group": "navigation"
        },
        {
          "command": "taskDock.updateTask",
          "when": "(view == taskDock.myRecentTasks || view == taskDock.allProjects) && viewItem == task",
          "group": "navigation"
        },
        {
          "command": "taskDock.deleteTask",
          "when": "(view == taskDock.myRecentTasks || view == taskDock.allProjects) && viewItem == task",
          "group": "navigation"
        },
        {
          "command": "taskDock.createSubtask",
          "when": "(view == taskDock.myRecentTasks || view == taskDock.allProjects) && (viewItem == task || viewItem == subtask)",
          "group": "navigation"
        },
        {
          "command": "taskDock.createTaskInDb",
          "when": "view == taskDock.allProjects && viewItem == database",
          "group": "navigation"
        },
        {
          "command": "taskDock.createTaskInProject",
          "when": "view == taskDock.allProjects && viewItem == project",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.extension.json",
    "watch": "tsc -watch -p tsconfig.extension.json",
    "postinstall": "electron-rebuild -v 39.8.7",
    "rebuild:electron": "electron-rebuild -v 39.8.7",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
